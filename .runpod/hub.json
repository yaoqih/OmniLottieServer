{
  "title": "OmniLottie_server",
  "description": "Serverless Lottie generation from text, image, or video via OmniLottie. Runpod-ready.",
  "type": "serverless",
  "category": "image",
  "config": {
    "runsOn": "GPU",
    "containerDiskInGb": 10,
    "gpuCount": 1,
    "gpuIds": [
      "Tesla T4",
      "NVIDIA RTX A4000",
      "NVIDIA RTX A4500",
      "NVIDIA RTX A5000",
      "NVIDIA RTX A30",
      "NVIDIA A30",
      "NVIDIA GeForce RTX 3080TI",
      "NVIDIA GeForce RTX 3090",
      "NVIDIA GeForce RTX 4090",
      "NVIDIA L4",
      "NVIDIA RTX 4000 Ada Generation",
      "NVIDIA RTX 5000 Ada Generation",
      "NVIDIA A40",
      "NVIDIA RTX A6000",
      "Tesla V100-FHHL-16GB",
      "Tesla V100-PCIE-16GB",
      "Tesla V100-PCIE-32GB",
      "Tesla V100-SXM2-16GB",
      "Tesla V100-SXM2-32GB",
      "NVIDIA L40",
      "NVIDIA L40S",
      "NVIDIA RTX 6000 Ada Generation",
      "NVIDIA RTX PRO 6000 Blackwell Server Edition",
      "NVIDIA RTX PRO 6000 Blackwell Workstation Edition",
      "NVIDIA A100 80GB PCIe"
    ],
    "allowedCudaVersions": ["11.8", "12.0", "12.1", "12.2", "12.3", "12.4", "12.5", "12.6", "12.7", "12.8", "12.9", "13.0"],
    "presets": [
      {
        "name": "Default",
        "defaults": {
          "MODEL_PATH": "OmniLottie/OmniLottie",
          "PROCESSOR_PATH": "Qwen/Qwen2.5-VL-3B-Instruct",
          "ENABLE_DUMMY": "true"
        }
      }
    ],
    "env": [
      {
        "key": "MODEL_PATH",
        "input": {
          "name": "OmniLottie model id or path",
          "type": "string",
          "description": "HuggingFace repo id for RunPod cached models, or a local path if you still use a volume",
          "default": "OmniLottie/OmniLottie"
        }
      },
      {
        "key": "PROCESSOR_PATH",
        "input": {
          "name": "Processor model id or path",
          "type": "string",
          "description": "HuggingFace repo id for the Qwen processor, or a local path if you still use a volume",
          "default": "Qwen/Qwen2.5-VL-3B-Instruct"
        }
      },
      {
        "key": "ENABLE_DUMMY",
        "input": {
          "name": "Enable dummy mode",
          "type": "boolean",
          "description": "Return a lightweight placeholder Lottie without loading large weights.",
          "default": true
        }
      }
    ]
  }
}
