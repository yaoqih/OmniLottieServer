{
  "title": "OmniLottie_server",
  "description": "Serverless Lottie generation from text, image, or video via OmniLottie. Runpod-ready.",
  "type": "serverless",
  "category": "image",
  "config": {
    "runsOn": "GPU",
    "containerDiskInGb": 10,
    "gpuCount": 1,
    "gpuIds": [
      "NVIDIA A40",
      "NVIDIA A100 80GB PCIe",
      "NVIDIA L40S",
      "NVIDIA RTX 6000 Ada Generation",
      "Tesla V100-SXM2-32GB"
    ],
    "allowedCudaVersions": ["12.1", "12.2", "12.3", "12.4", "12.5", "12.6", "12.7", "12.8", "12.9", "13.0"],
    "presets": [
      {
        "name": "Default",
        "defaults": {
          "MODEL_PATH": "/runpod-volume/OmniLottie",
          "PROCESSOR_PATH": "/runpod-volume/Qwen2.5-VL-3B-Instruct",
          "ENABLE_DUMMY": "true"
        }
      }
    ],
    "env": [
      {
        "key": "MODEL_PATH",
        "input": {
          "name": "OmniLottie model path",
          "type": "string",
          "description": "Local path or HuggingFace repo id for the OmniLottie HF model",
          "default": "/runpod-volume/OmniLottie"
        }
      },
      {
        "key": "PROCESSOR_PATH",
        "input": {
          "name": "Processor path",
          "type": "string",
          "description": "Local path or HuggingFace repo id for the Qwen processor",
          "default": "/runpod-volume/Qwen2.5-VL-3B-Instruct"
        }
      },
      {
        "key": "ENABLE_DUMMY",
        "input": {
          "name": "Enable dummy mode",
          "type": "boolean",
          "description": "Return a lightweight placeholder Lottie without loading large weights.",
          "default": true
        }
      }
    ]
  }
}
